{
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "{env:CONTEXT7_API_KEY}",
      ],
      "enabled": true,
    },
    "jira": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": true,
    },
    "sap-jira": {
      "type": "remote",
      "url": "https://mcp.jira.tools.sap/mcp/",
      "enabled": true,
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking",
      ],
    },
    "memory": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-memory"],
      "environment": {
        "MEMORY_FILE_PATH": "/home/i525646/.local/share/opencode/memory.json",
      },
    },
    "cloudflare-api": {
      "type": "remote",
      "url": "https://mcp.cloudflare.com/mcp",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:CLOUDFLARE_API_TOKEN}"
      }
    }
  },
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md", "MEMORY.md"],
  "plugin": [
    "oh-my-opencode@3.14.0",
    "cc-safety-net",
    "@franlol/opencode-md-table-formatter@latest",
    //"@tarquinen/opencode-dcp@latest",
  ],
  "disabled_providers": ["google", "opencode", "cloudflare-ai-gateway"],
  "provider": {
    "anthropic": {
      "options": {
        "baseURL": "http://localhost:6655/anthropic/v1",
        "apiKey": "{env:LLM_PROXY_KEY}",
      },
      "whitelist": ["claude-opus-4-6", "claude-sonnet-4-6", "claude-haiku-4-5"],
    },
    "openai": {
      "options": {
        "baseURL": "http://localhost:6655/openai/v1",
        "apiKey": "{env:LLM_PROXY_KEY}",
      },
      "whitelist": ["gpt-5", "gpt-5-mini"],
    },
    "github-copilot": {
      "whitelist": [
        "claude-opus-4.6",
        "claude-sonnet-4.6",
        "claude-haiku-4.5",
        "gemini-2.5-pro",
        "gpt-5.3-codex",
        "gpt-5.3",
        "gpt-5.2-codex",
        "gpt-5.2",
        "gpt-5.1-codex-max",
        "gpt-5.1",
        "gpt-5-mini",
      ],
    },
    "fireworks-ai": {
      "options": {
        "apiKey": "{env:FIREWORKS_API_KEY}",
      },
    },
    "google": {
      "whitelist": [
        "gemini-2.5-pro",
        "gemini-2.5-flash",
        "gemini-3-flash-preview",
        "gemini-3.0-pro-preview",
        "gemini-3.1-pro-preview",
        "gemini-3.1-pro-preview-customtools",
      ],
    },
  },
  "compaction": {
    "auto": false,
    "prune": true,
    "reserved": 10000,
  },
}
