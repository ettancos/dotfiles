[user]
  email = tamas.tancos@emarsys.com
  name = Tamas Tancos
  signingkey = 9FB36F450A4D483747098D1F627645F33BDD8808
[color]
  ui = auto
[column]
  ui = auto
[core]
  autocrlf = input
  excludesFile = ~/.config/git/ignore
#  sshCommand = "ssh -vvvvv"
[init]
	defaultBranch = main
[interactive]
  singlekey = true
[grep]
  lineNumber = true
[diff]
  mnemonicprefix = true
  rename = copy
  algorithm = histogram
  colorMoved = plain
[push]
	default = simple
  autoSetupRemote = true
  followTags = true
[pull]
	rebase = true
[merge]
  conflictstyle = zdiff3
	; tool = vscode
[branch]
  sort = -committerdate
[tag]
  sort = version:refname
[alias]
	co = checkout
	cob = checkout -b
	ci = commit
	st = status -sb
	b = branch -a
	l = log -5 --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold cyan)%ai%C(reset) - %C(bold white)%an%C(reset) %C(bold green)(%ar)%C(reset)%C(bold yellow)%d%C(reset)%n %C(white)%s%C(reset)'
	hist = log --pretty=format:\"%h %ad | %s%d [%an]\" --graph --date=short
[credential]
  #helper = /usr/lib/git-core/git-credential-libsecret
  #helper = /usr/share/doc/git/contrib/credential/libsecret
  #helper = /usr/share/doc/git/contrib/credential/gnome-keyring
  #helper = /usr/share/doc/git/contrib/credential/libsecret/git-credential-libsecret
[commit]
	template = ~/.config/git/message
  gpgsign = true
