set selection-clipboard clipboard
set font "monospace normal 11"
set show-recent 0
set adjust-open "width"
set pages-per-row 2
set default-bg "#2e3440"
set inputbar-bg "#2e3440"
set statusbar-bg "#434c5e"
set window-height 540
set window-width 960

map <C-l> reload
map <C-i> recolor
map H jumplist backward
map L jumplist forward
map ; focus_inputbar ":"
map <A-;> abort
